{
  "id": "example-profile",
  "name": "Example Browser Profile",
  "userAgent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36",
  "viewport": {
    "width": 1920,
    "height": 1080
  },
  "localStorage": {
    "example.com": {
      "theme": "dark",
      "language": "en-US"
    }
  },
  "cookies": [
    {
      "name": "session_id",
      "value": "abc123def456",
      "domain": "example.com",
      "path": "/",
      "httpOnly": true,
      "secure": true,
      "sameSite": "Lax"
    }
  ],
  "headers": {
    "Accept-Language": "en-US,en;q=0.9"
  }
}